# Local dev (không Docker) — copy: cp .env.example .env.local
# Docker: chỉ dùng docker/.env.example | docker/.env.local | docker/.env

# App (Next.js dev)
NEXT_PUBLIC_APP_URL=http://localhost:6789

# API (BE dev — Scalar: http://localhost:8386/scalar)
NEXT_PUBLIC_API_URL=http://localhost:8386/

# production | development
NEXT_PUBLIC_ENV=development
