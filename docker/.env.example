# Chuẩn env Docker — chỉ 3 file trong docker/:
#   .env.example  → mẫu (commit)
#   .env          → production (gitignore, copy từ mục PROD bên dưới)
#   .env.local    → development (gitignore, copy từ mục DEV bên dưới)
#
# Dev:  npm run docker:dev   → đọc docker/.env.local
# Prod: npm run docker:prod  → đọc docker/.env

# --- DEV (copy vào .env.local) ---
# NEXT_PUBLIC_APP_URL=http://localhost:6789
# NEXT_PUBLIC_API_URL=http://localhost:8386/
# NEXT_PUBLIC_APP_NAME=Wokki
# NEXT_PUBLIC_ENV=development

# --- PROD (copy vào .env) ---
# NEXT_PUBLIC_APP_URL=https://app.example.com
# NEXT_PUBLIC_API_URL=https://api.example.com/
# NEXT_PUBLIC_APP_NAME=Wokki
# NEXT_PUBLIC_ENV=production
