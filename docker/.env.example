# Copy to .env.local (dev) or .env (prod) and chỉnh domain / URL thật
#
# Dev (docker-compose.dev.yml):
#   cp .env.example .env.local
#
# Prod (docker-compose.prod.yml):
#   cp .env.example .env
#   Đổi api.example.com / app.example.com thành domain production

# URL API — phải reachable từ trình duyệt (NEXT_PUBLIC_* embed lúc build prod)
NEXT_PUBLIC_API_URL=http://localhost:8386/
NEXT_PUBLIC_APP_NAME=Wokki
NEXT_PUBLIC_APP_URL=http://localhost:6789
NEXT_PUBLIC_ENV=development
